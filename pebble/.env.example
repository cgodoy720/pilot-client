# Pebble API — Required
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — free worker-tier models (optional, falls back to Anthropic Haiku)
OPENROUTER_API_KEY=

# Optional — for FEC contributor search (use DEMO_KEY for testing)
FEC_API_KEY=DEMO_KEY

# Required for officer search (free tier: 500 req/month, 401 without token)
OPENCORPORATES_API_KEY=

# Pebble API key (for Bedrock client auth)
PEBBLE_API_KEY=
