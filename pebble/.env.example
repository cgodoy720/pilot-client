# Pebble API — Required
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — free worker-tier models (optional, falls back to Anthropic Haiku)
OPENROUTER_API_KEY=

# Optional — for FEC contributor search (use DEMO_KEY for testing)
FEC_API_KEY=DEMO_KEY

# Required for officer search (free tier: 500 req/month, 401 without token)
OPENCORPORATES_API_KEY=

# Google Programmable Search Engine (curated 50 domains)
# Free tier: 100 queries/day. $5/1,000 queries after.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Serper.dev — unrestricted web search (free tier: 2,500 queries)
# Complements Google CSE with full web coverage
SERPER_API_KEY=

# Pebble API key (for Bedrock client auth)
PEBBLE_API_KEY=
