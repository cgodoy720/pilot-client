VITE_API_URL=http://localhost:7001

# Google Drive Picker — used by the Headshot Upload tool (/admin/headshots)
# Both values come from the same GCP project used for GCS.
# Setup: Cloud Console → APIs & Services
#   1. Enable "Google Picker API"
#   2. Create an API Key (restrict to Picker API) → VITE_GOOGLE_PICKER_API_KEY
#   3. Create an OAuth 2.0 Client ID (Web application, add your frontend URL as
#      an authorized JS origin) → VITE_GOOGLE_PICKER_CLIENT_ID
# Leave blank to hide the "Pick from Google Drive" button.
VITE_GOOGLE_PICKER_API_KEY=
VITE_GOOGLE_PICKER_CLIENT_ID=