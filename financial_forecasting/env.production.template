# Production Environment Variables Template
# This file shows what environment variables you need to set in Cloud Run
# DO NOT commit actual secrets to git!

# ============================================================================
# REQUIRED: Google OAuth Configuration
# ============================================================================
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
# This will be your Cloud Run backend URL + /auth/google/callback
GOOGLE_REDIRECT_URI=https://financial-forecasting-api-XXXXXX.run.app/auth/google/callback

# ============================================================================
# REQUIRED: JWT Secret for Session Tokens
# ============================================================================
# Production REQUIRES a strong random secret (min 32 chars). Generate with:
#   openssl rand -hex 32
# The app will fail to start in production if JWT_SECRET_KEY is missing or weak.
JWT_SECRET_KEY=your-very-long-random-secret-key-minimum-32-characters

# ============================================================================
# REQUIRED: Fireflies API
# ============================================================================
# Get from: https://app.fireflies.ai/integrations/custom/fireflies-api
FIREFLIES_API_KEY=your-fireflies-api-key

# ============================================================================
# OPTIONAL: Slack Integration
# ============================================================================
# Get from: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ============================================================================
# SALESFORCE CREDENTIALS
# ============================================================================
SALESFORCE_CLIENT_ID=your-salesforce-connected-app-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-connected-app-client-secret
SALESFORCE_USERNAME=your-salesforce-username@domain.com
SALESFORCE_PASSWORD=your-password
SALESFORCE_SECURITY_TOKEN=your-security-token
SALESFORCE_DOMAIN=login  # or 'test' for sandbox

# ============================================================================
# OPTIONAL: PBD Shared Calendar
# ============================================================================
# Override only if using a different PBD calendar. Default is hardcoded fallback.
# PBD_CALENDAR_ID=c_xxxxx@group.calendar.google.com

# ============================================================================
# ACCESS CONTROL (recommended for production)
# ============================================================================
# Comma-separated list of allowed email addresses. If set, only these users can log in.
# ALLOWED_EMAILS=user1@pursuit.org,user2@pursuit.org

# ============================================================================
# DEPLOYMENT INFO
# ============================================================================
# These are set automatically by Cloud Run
# PORT=8080
# K_SERVICE=financial-forecasting-api
# K_REVISION=financial-forecasting-api-00001

